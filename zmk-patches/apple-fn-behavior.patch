@@ -316,8 +319,42 @@ bool zmk_hid_keyboard_is_pressed(zmk_key_t code) {

 void zmk_hid_keyboard_clear(void) {
     memset(&keyboard_report.body, 0, sizeof(keyboard_report.body));
+    apple_fn_count = 0;
 }

+int zmk_hid_apple_fn_press(void) {
+    apple_fn_count++;
+
+    if (keyboard_report.body._reserved == 1) {
+        return 0;
+    }
+
+    keyboard_report.body._reserved = 1;
+    LOG_DBG("Apple Fn pressed");
+    return 1;
+}
+
+int zmk_hid_apple_fn_release(void) {
+    if (apple_fn_count <= 0) {
+        LOG_ERR("Tried to release Apple Fn too often");
+        return -EINVAL;
+    }
+
+    apple_fn_count--;
+    if (apple_fn_count > 0) {
+        return 0;
+    }
+
+    keyboard_report.body._reserved = 0;
+    LOG_DBG("Apple Fn released");
+    return 1;
+}
+
+bool zmk_hid_apple_fn_is_pressed(void) {
+    return keyboard_report.body._reserved == 1;
+}
